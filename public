                    </div>
                    <h2 class="text-3xl font-bold gradient-text-luxury">توليد الصور بالذكاء الاصطناعي</h2>
                    <p class="text-gray-400 mt-2">حوّل خيالك إلى واقع باستخدام DALL-E 3</p>
                </div>
                
                <textarea id="imagePrompt" rows="4" 
                    class="w-full px-5 py-3 bg-white/5 border border-white/10 rounded-xl focus:outline-none focus:border-purple-500 text-white placeholder-gray-500 mb-5"
                    placeholder="وصف الصورة... مثال: منظر طبيعي ساحر مع جبال مغطاة بالثلوج وقوس قزح في السماء، أسلوب سينمائي فاخر"></textarea>
                
                <button onclick="generateImage()" class="btn-luxury w-full py-3">
                    <i class="fas fa-sparkle ml-2"></i>توليد الصورة
                </button>
                
                <div id="imageResult" class="mt-8 text-center"></div>
            </div>
        </div>
        
        <!-- صفحة النصوص -->
        <div id="text" class="page">
            <div class="glass-luxury p-8">
                <h2 class="text-3xl font-bold gradient-text-luxury text-center mb-8">📝 تحرير النصوص بذكاء</h2>
                
                <div class="grid md:grid-cols-2 gap-8">
                    <div class="glass-card p-6">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-pink-600 rounded-xl flex items-center justify-center">
                                <i class="fas fa-compress text-white"></i>
                            </div>
                            <h3 class="text-xl font-bold text-white">تلخيص النصوص</h3>
                        </div>
                        <textarea id="summaryInput" rows="4" 
                            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl focus:outline-none focus:border-purple-500 text-white placeholder-gray-500 mb-4"
                            placeholder="أدخل النص المراد تلخيصه..."></textarea>
                        <button onclick="summarizeText()" class="btn-luxury w-full py-2">تلخيص</button>
                        <div id="summaryResult" class="mt-4 hidden"></div>
                    </div>
                    
                    <div class="glass-card p-6">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-12 h-12 bg-gradient-to-br from-purple-600 to-pink-600 rounded-xl flex items-center justify-center">
                                <i class="fas fa-language text-white"></i>
                            </div>
                            <h3 class="text-xl font-bold text-white">ترجمة فورية</h3>
                        </div>
                        <textarea id="translateInput" rows="4" 
                            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl focus:outline-none focus:border-purple-500 text-white placeholder-gray-500 mb-4"
                            placeholder="أدخل النص للترجمة..."></textarea>
                        <div class="flex gap-3 mb-4">
                            <select id="targetLang" class="flex-1 px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-white">
                                <option value="الإنجليزية">الإنجليزية</option>
                                <option value="الفرنسية">الفرنسية</option>
                                <option value="الألمانية">الألمانية</option>
                                <option value="الإسبانية">الإسبانية</option>
                            </select>
                            <button onclick="translateText()" class="btn-luxury px-6">ترجمة</button>
                        </div>
                        <div id="translateResult" class="mt-4 hidden"></div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- صفحة الأكواد -->
        <div id="code" class="page">
            <div class="glass-luxury p-8">
                <div class="text-center mb-8">
                    <div class="w-20 h-20 bg-gradient-to-br from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-terminal text-3xl text-white"></i>
                    </div>
                    <h2 class="text-3xl font-bold gradient-text-luxury">توليد الأكواد البرمجية</h2>
                    <p class="text-gray-400 mt-2">اطلب الكود بلغتك المفضلة</p>
                </div>
                
                <select id="codeLanguage" class="w-full mb-5 px-5 py-3 bg-white/5 border border-white/10 rounded-xl text-white">
                    <option value="Python">🐍 Python</option>
                    <option value="JavaScript">⚡ JavaScript</option>
                    <option value="Java">☕ Java</option>
                    <option value="C++">⚙️ C++</option>
                    <option value="HTML/CSS">🎨 HTML/CSS</option>
                </select>
                
                <textarea id="codeDescription" rows="4" 
                    class="w-full px-5 py-3 bg-white/5 border border-white/10 rounded-xl focus:outline-none focus:border-purple-500 text-white placeholder-gray-500 mb-5"
                    placeholder="وصف الكود المطلوب... مثال: دالة لحساب الأعداد الأولية من 1 إلى 100"></textarea>
                
                <button onclick="generateCode()" class="btn-luxury w-full py-3">
                    <i class="fas fa-code ml-2"></i>توليد الكود
                </button>
                
                <div id="codeResult" class="mt-8 hidden"></div>
            </div>
        </div>
        
        <!-- صفحة الأفكار -->
        <div id="ideas" class="page">
            <div class="glass-luxury p-8">
                <div class="text-center mb-8">
                    <div class="w-20 h-20 bg-gradient-to-br from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-4 float-animation">
                        <i class="fas fa-lightbulb text-3xl text-white"></i>
                    </div>
                    <h2 class="text-3xl font-bold gradient-text-luxury">أفكار مشاريع إبداعية</h2>
                    <p class="text-gray-400 mt-2">احصل على أفكار مبتكرة لمشاريعك القادمة</p>
                </div>
                
                <select id="ideaField" class="w-full mb-5 px-5 py-3 bg-white/5 border border-white/10 rounded-xl text-white">
                    <option value="التجارة الإلكترونية">🛒 التجارة الإلكترونية</option>
                    <option value="التعليم">📚 التعليم</option>
                    <option value="الصحة">🏥 الصحة</option>
                    <option value="التكنولوجيا">💻 التكنولوجيا</option>
                    <option value="الترفيه">🎮 الترفيه</option>
                </select>
                
                <button onclick="generateIdeas()" class="btn-luxury w-full py-3">
                    <i class="fas fa-brain ml-2"></i>توليد الأفكار
                </button>
                
                <div id="ideasResult" class="mt-8 hidden"></div>
            </div>
        </div>
        
        <!-- صفحة الإعدادات -->
        <div id="settings" class="page">
            <div class="glass-luxury p-8 max-w-2xl mx-auto">
                <div class="text-center mb-8">
                    <div class="w-20 h-20 bg-gradient-to-br from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-crown text-3xl text-white"></i>
                    </div>
                    <h2 class="text-3xl font-bold gradient-text-luxury">الإعدادات المتقدمة</h2>
                    <p class="text-gray-400 mt-2">أدخل مفاتيح API الخاصة بك</p>
                </div>
                
                <div class="glass-card p-5 mb-6">
                    <i class="fas fa-shield-alt text-purple-500 ml-2"></i>
                    <span class="text-gray-300 text-sm">مفاتيح API الخاصة بك آمنة ومشفرة بشكل كامل</span>
                </div>
                
                <div class="space-y-5">
                    <div>
                        <label class="block text-white font-semibold mb-2">🔑 OpenAI API Key</label>
                        <input type="password" id="openaiKey" 
                            class="w-full px-5 py-3 bg-white/5 border border-white/10 rounded-xl focus:outline-none focus:border-purple-500 text-white font-mono"
                            placeholder="sk-proj-...">
                        <p class="text-xs text-gray-500 mt-1">يستخدم لـ: الدردشة، الصور، التلخيص، الترجمة، الأكواد، الأفكار</p>
                    </div>
                    
                    <div>
                        <label class="block text-white font-semibold mb-2">🔑 Google Gemini API Key</label>
                        <input type="password" id="geminiKey" 
                            class="w-full px-5 py-3 bg-white/5 border border-white/10 rounded-xl focus:outline-none focus:border-purple-500 text-white font-mono"
                            placeholder="AIza...">
                        <p class="text-xs text-gray-500 mt-1">يستخدم لـ: الدردشة الذكية</p>
                    </div>
                    
                    <button onclick="saveApiKeys()" class="btn-luxury w-full py-3">
                        <i class="fas fa-save ml-2"></i>حفظ الإعدادات
                    </button>
                </div>
            </div>
        </div>
        
    </main>
    
    <script>
        function createParticles() {
            const container = document.getElementById('particles');
            if (!container) return;
            for (let i = 0; i < 50; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                const size = Math.random() * 4 + 2;
                particle.style.width = size + 'px';
                particle.style.height = size + 'px';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 15 + 's';
                particle.style.animationDuration = (Math.random() * 20 + 10) + 's';
                container.appendChild(particle);
            }
        }
        createParticles();
        
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            localStorage.setItem('currentPage', pageId);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        
        const themeToggle = document.getElementById('themeToggle');
        const body = document.body;
        
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'light') {
            body.classList.remove('dark');
            themeToggle.innerHTML = '<i class="fas fa-moon text-lg"></i>';
        } else {
            body.classList.add('dark');
            themeToggle.innerHTML = '<i class="fas fa-sun text-lg"></i>';
        }
        
        themeToggle.addEventListener('click', () => {
            if (body.classList.contains('dark')) {
                body.classList.remove('dark');
                themeToggle.innerHTML = '<i class="fas fa-moon text-lg"></i>';
                localStorage.setItem('theme', 'light');
            } else {
                body.classList.add('dark');
                themeToggle.innerHTML = '<i class="fas fa-sun text-lg"></i>';
                localStorage.setItem('theme', 'dark');
            }
        });
        
        const lastPage = localStorage.getItem('currentPage');
        if (lastPage && lastPage !== 'home') showPage(lastPage);
        
        async function sendMessage() {
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            if (!message) {
                Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى كتابة رسالة', background: '#1A1A3E', color: '#fff' });
                return;
            }
            
            const provider = document.getElementById('chatProvider').value;
            const chatDiv = document.getElementById('chatMessages');
            
            chatDiv.innerHTML += `
                <div class="flex justify-end">
                    <div class="message-user">
                        ${escapeHtml(message)}
                    </div>
                </div>
            `;
            input.value = '';
            
            chatDiv.innerHTML += `
                <div class="flex justify-start" id="loadingMsg">
                    <div class="bg-white/5 border border-white/10 rounded-2xl rounded-bl-none px-5 py-3">
                        <div class="luxury-spinner" style="width:24px;height:24px;"></div>
                    </div>
                </div>
            `;
            chatDiv.scrollTop = chatDiv.scrollHeight;
            
            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message, provider })
                });
                const data = await response.json();
                
                document.getElementById('loadingMsg')?.remove();
                if (data.response) {
                    chatDiv.innerHTML += `
                        <div class="flex justify-start">
                            <div class="message-bot">
                                ${escapeHtml(data.response)}
                            </div>
                        </div>
                    `;
                } else {
                    chatDiv.innerHTML += `
                        <div class="flex justify-start">
                            <div class="bg-red-500/20 border border-red-500/30 rounded-2xl rounded-bl-none px-4 py-2 text-red-400">
                                ⚠️ خطأ: ${escapeHtml(data.error)}
                            </div>
                        </div>
                    `;
                }
                chatDiv.scrollTop = chatDiv.scrollHeight;
            } catch (error) {
                document.getElementById('loadingMsg')?.remove();
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'حدث خطأ في الاتصال', background: '#1A1A3E', color: '#fff' });
            }
        }
        
        async function generateImage() {
            const prompt = document.getElementById('imagePrompt').value;
            if (!prompt) {
                Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى إدخال وصف للصورة', background: '#1A1A3E', color: '#fff' });
                return;
            }
            
            const resultDiv = document.getElementById('imageResult');
            resultDiv.innerHTML = '<div class="luxury-spinner mx-auto"></div><p class="text-center mt-4 text-gray-400">✨ جاري توليد صورتك الفاخرة...</p>';
            
            try {
                const response = await fetch('/api/generate-image', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt })
                });
                const data = await response.json();
                
                if (data.imageUrl) {
                    resultDiv.innerHTML = `
                        <div class="glass-card p-4">
                            <img src="${data.imageUrl}" class="rounded-xl shadow-2xl mx-auto max-w-full">
                            <button onclick="downloadImage('${data.imageUrl}')" class="mt-4 btn-luxury px-6 py-2">
                                <i class="fas fa-download ml-2"></i>تحميل الصورة
                            </button>
                        </div>
                    `;
                } else {
                    resultDiv.innerHTML = `<p class="text-red-400 text-center">⚠️ ${data.error}</p>`;
                }
            } catch (error) {
                resultDiv.innerHTML = '<p class="text-red-400 text-center">⚠️ حدث خطأ في الاتصال</p>';
            }
        }
        
        async function summarizeText() {
            const text = document.getElementById('summaryInput').value;
            if (!text) {
                Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى إدخال النص', background: '#1A1A3E', color: '#fff' });
                return;
            }
            
            const resultDiv = document.getElementById('summaryResult');
            resultDiv.classList.remove('hidden');
            resultDiv.innerHTML = '<div class="luxury-spinner" style="width:24px;height:24px;margin:0 auto;"></div><p class="text-center mt-2 text-gray-400">جاري التلخيص...</p>';
            
            try {
                const response = await fetch('/api/summarize', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text })
                });
                const data = await response.json();
                
                if (data.summary) {
                    resultDiv.innerHTML = `<div class="glass-card p-4 text-gray-300">${escapeHtml(data.summary)}</div>`;
                } else {
                    resultDiv.innerHTML = `<div class="text-red-400">⚠️ ${data.error}</div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = '<div class="text-red-400">⚠️ حدث خطأ</div>';
            }
        }
        
        async function translateText() {
            const text = document.getElementById('translateInput').value;
            const targetLang = document.getElementById('targetLang').value;
            if (!text) {
                Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى إدخال النص', background: '#1A1A3E', color: '#fff' });
                return;
            }
            
            const resultDiv = document.getElementById('translateResult');
            resultDiv.classList.remove('hidden');
            resultDiv.innerHTML = '<div class="luxury-spinner" style="width:24px;height:24px;margin:0 auto;"></div><p class="text-center mt-2 text-gray-400">جاري الترجمة...</p>';
            
            try {
                const response = await fetch('/api/translate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text, targetLang })
                });
                const data = await response.json();
                
                if (data.translation) {
                    resultDiv.innerHTML = `<div class="glass-card p-4 text-gray-300">${escapeHtml(data.translation)}</div>`;
                } else {
                    resultDiv.innerHTML = `<div class="text-red-400">⚠️ ${data.error}</div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = '<div class="text-red-400">⚠️ حدث خطأ</div>';
            }
        }
        
        async function generateCode() {
            const description = document.getElementById('codeDescription').value;
            const language = document.getElementById('codeLanguage').value;
            if (!description) {
                Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى إدخال وصف الكود', background: '#1A1A3E', color: '#fff' });
                return;
            }
            
            const resultDiv = document.getElementById('codeResult');
            resultDiv.classList.remove('hidden');
            resultDiv.innerHTML = '<div class="luxury-spinner mx-auto"></div><p class="text-center mt-4 text-gray-400">✨ جاري توليد الكود...</p>';
            
            try {
                const response = await fetch('/api/generate-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ description, language })
                });
                const data = await response.json();
                
                if (data.code) {
                    resultDiv.innerHTML = `
                        <div class="bg-black/50 rounded-xl p-5 overflow-x-auto">
                            <pre class="text-green-400 font-mono text-sm whitespace-pre-wrap">${escapeHtml(data.code)}</pre>
                        </div>
                        <button onclick="copyToClipboard('${escapeHtml(data.code)}')" class="mt-4 btn-outline-luxury px-6 py-2">
                            <i class="fas fa-copy ml-2"></i>نسخ الكود
                        </button>
                    `;
                } else {
                    resultDiv.innerHTML = `<p class="text-red-400 text-center">⚠️ ${data.error}</p>`;
                }
            } catch (error) {
                resultDiv.innerHTML = '<p class="text-red-400 text-center">⚠️ حدث خطأ</p>';
            }
        }
        
        async function generateIdeas() {
            const field = document.getElementById('ideaField').value;
            const resultDiv = document.getElementById('ideasResult');
            resultDiv.classList.remove('hidden');
            resultDiv.innerHTML = '<div class="luxury-spinner mx-auto"></div><p class="text-center mt-4 text-gray-400">💡 جاري توليد الأفكار الإبداعية...</p>';
            
            try {
                const response = await fetch('/api/generate-ideas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ field })
                });
                const data = await response.json();
                
                if (data.ideas) {
                    resultDiv.innerHTML = `
                        <div class="glass-card p-6">
                            <div class="whitespace-pre-wrap text-gray-300 leading-relaxed">${escapeHtml(data.ideas)}</div>
                        </div>
                    `;
                } else {
                    resultDiv.innerHTML = `<p class="text-red-400 text-center">⚠️ ${data.error}</p>`;
                }
            } catch (error) {
                resultDiv.innerHTML = '<p class="text-red-400 text-center">⚠️ حدث خطأ</p>';
            }
        }
        
        async function saveApiKeys() {
            const openai = document.getElementById('openaiKey').value;
            const gemini = document.getElementById('geminiKey').value;
            
            try {
                const response = await fetch('/api/save-keys', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ openai, gemini })
                });
                const data = await response.json();
                
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'تم الحفظ', text: 'تم حفظ مفاتيح API بنجاح', background: '#1A1A3E', color: '#fff' });
                } else {
                    Swal.fire({ icon: 'error', title: 'خطأ', text: 'حدث خطأ في حفظ المفاتيح', background: '#1A1A3E', color: '#fff' });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'حدث خطأ في الاتصال', background: '#1A1A3E', color: '#fff' });
            }
        }
        
        function downloadImage(url) {
            const link = document.createElement('a');
            link.href = url;
            link.download = `yaqoub-${Date.now()}.png`;
            link.click();
        }
        
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text);
            Swal.fire({ icon: 'success', title: 'تم النسخ', text: 'تم نسخ الكود إلى الحافظة', background: '#1A1A3E', color: '#fff', timer: 1500 });
        }
        
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        document.getElementById('chatInput')?.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });
        
        gsap.from('.glass-card', {
            scrollTrigger: {
                trigger: '.glass-card',
                start: 'top 90%',
            },
            y: 50,
            opacity: 0,
            duration: 0.8,
            stagger: 0.2
        });
    </script>
</body>
</html>
