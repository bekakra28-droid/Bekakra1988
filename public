                </div>
                
                <div class="hidden md:flex items-center gap-6">
                    <button onclick="showPage('home')" class="text-gray-300 hover:text-purple-400 transition">الرئيسية</button>
                    <button onclick="showPage('tools')" class="text-gray-300 hover:text-purple-400 transition">الأدوات</button>
